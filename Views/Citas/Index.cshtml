@model IEnumerable<PostaCitasWeb.Entities.Cita>

@{
    ViewData["Title"] = "Gestión de Citas";
}

<div class="container py-4">
    <div class="card shadow-sm mb-4">
        <div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <h1 class="h3 mb-1">Gestión de Citas</h1>
                <p class="text-muted mb-0">Consulta las citas registradas y accede a sus acciones permitidas.</p>
            </div>
            <a asp-action="Create" class="btn btn-success">
                Nueva Cita
            </a>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <strong>Listado de citas</strong>
            <span class="badge bg-primary">table-striped / table-hover</span>
        </div>
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Fecha</th>
                        <th>Paciente</th>
                        <th>Médico</th>
                        <th>Especialidad</th>
                        <th>Estado</th>
                        <th>Origen</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cita in Model)
                    {
                        var pacienteNombre = cita.Paciente?.Nombres ?? $"Paciente #{cita.PacienteId}";
                        var medicoNombre = cita.Slot?.Programacion?.Medico?.Nombres ?? $"Médico #{cita.Slot?.Programacion?.MedicoId ?? 0}";
                        var especialidadNombre = cita.Especialidad?.Nombre ?? $"Especialidad #{cita.EspecialidadId}";
                        <tr>
                            <td>@cita.FechaReserva.ToString("dd/MM/yyyy")</td>
                            <td>@pacienteNombre</td>
                            <td>@medicoNombre</td>
                            <td>@especialidadNombre</td>
                            <td>@cita.EstadoCita</td>
                            <td>@cita.OrigenReserva</td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm" role="group" aria-label="Acciones de cita">
                                    <a asp-controller="Citas" asp-action="Details" asp-route-id="@cita.CitaId" class="btn btn-outline-primary">Detalles</a>
                                    <a asp-controller="Citas" asp-action="Edit" asp-route-id="@cita.CitaId" class="btn btn-outline-secondary">Editar</a>
                                    <form asp-controller="Citas" asp-action="CancelConfirmed" asp-route-id="@cita.CitaId" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger">Cancelar Cita</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@model PostaCitasWeb.Models.ViewModels.PacienteDashboardViewModel

@{
    ViewData["Title"] = "Panel del Paciente";
}

<div class="container py-4">
    <div class="card shadow-sm mb-4">
        <div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <h1 class="h3 mb-1">Panel del Paciente</h1>
                <p class="text-muted mb-0">Consulta tus citas programadas y agenda una nueva cita.</p>
            </div>
            <a asp-controller="Citas" asp-action="Create" class="btn btn-success">
                Agendar Nueva Cita
            </a>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-white">
            <strong>Mis Citas Programadas</strong>
        </div>
        <div class="card-body p-0">
            <table class="table table-striped mb-0 align-middle">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Especialidad</th>
                        <th>Médico</th>
                        <th>Estado</th>
                        <th>Acción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cita in Model.MisCitas)
                    {
                        var especialidadNombre = cita.Especialidad?.Nombre ?? $"Especialidad #{cita.EspecialidadId}";
                        var medicoNombre = cita.Slot?.Programacion?.Medico?.Nombres ?? $"Médico #{cita.Slot?.Programacion?.MedicoId ?? 0}";
                        <tr>
                            <td>@cita.FechaReserva.ToString("dd/MM/yyyy")</td>
                            <td>@especialidadNombre</td>
                            <td>@medicoNombre</td>
                            <td>@cita.EstadoCita</td>
                            <td>
                                <a asp-controller="Citas" asp-action="Details" asp-route-id="@cita.CitaId" class="btn btn-sm btn-outline-primary">Ver detalle</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

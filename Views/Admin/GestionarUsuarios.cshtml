@model List<UsuarioViewModel>
@{
    ViewData["Title"] = "Gestionar Usuarios - CU18";
}

<div class="container py-4">
    <div class="card shadow-sm mb-4">
        <div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <h1 class="h3 mb-1">Gestionar Usuarios y Personal</h1>
                <p class="text-muted mb-0">Registrar, buscar y administrar roles de Pacientes, Médicos, Enfermeras y Personal de Admisión.</p>
            </div>
            <a href="@Url.Action("Index", "Admin")" class="btn btn-outline-secondary">Volver al Panel</a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-white border-bottom">
                    <h5 class="mb-0">Crear/Editar Usuario</h5>
                </div>
                <div class="card-body">
                    <form id="formUsuario">
                        <div class="mb-3">
                            <label for="DNI" class="form-label">DNI</label>
                            <div class="input-group">
                                <input type="text"
                                       class="form-control"
                                       id="DNI"
                                       name="DNI"
                                       maxlength="8"
                                       placeholder="Ingrese 8 dígitos"
                                       required>
                                <button type="button"
                                        class="btn btn-primary"
                                        id="btnBuscarDni">
                                    Buscar
                                </button>
                            </div>
                            <small class="form-text text-muted">Ingrese exactamente 8 dígitos numéricos</small>
                        </div>

                        <div class="mb-3">
                            <label for="NombreUsuario" class="form-label">Nombre Completo (Autocompletado)</label>
                            <input type="text"
                                   class="form-control bg-light"
                                   id="NombreUsuario"
                                   name="NombreUsuario"
                                   readonly
                                   required>
                        </div>

                        <div class="mb-3">
                            <label for="Rol" class="form-label">Rol</label>
                            <select class="form-select" id="Rol" name="Rol" required>
                                <option value="">Seleccione un rol</option>
                                <option value="0">Paciente</option>
                                <option value="1">Admisión</option>
                                <option value="2">Enfermería</option>
                                <option value="3">Administrador</option>
                                <option value="4">Médico</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="Celular" class="form-label">Celular</label>
                            <input type="text"
                                   class="form-control"
                                   id="Celular"
                                   name="Celular"
                                   maxlength="15"
                                   placeholder="Ej: 987654321"
                                   required>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="Password" class="form-label">Contraseña temporal</label>
                                <input type="password"
                                       class="form-control"
                                       id="Password"
                                       name="Password"
                                       required>
                            </div>
                            <div class="col-md-6">
                                <label for="ConfirmPassword" class="form-label">Confirmar Contraseña</label>
                                <input type="password"
                                       class="form-control"
                                       id="ConfirmPassword"
                                       name="ConfirmPassword"
                                       required>
                            </div>
                        </div>

                        <div class="mb-3 form-check">
                            <input type="checkbox"
                                   class="form-check-input"
                                   id="Activo"
                                   name="Activo"
                                   checked>
                            <label class="form-check-label" for="Activo">
                                Usuario Activo en el Sistema
                            </label>
                        </div>

                        <div class="d-flex justify-content-end gap-2 border-top pt-3">
                            <button type="reset" class="btn btn-outline-secondary" id="btnLimpiar">Limpiar</button>
                            <button type="submit" class="btn btn-success" id="btnGuardar">Guardar Usuario</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-white border-bottom">
                    <h5 class="mb-0">Usuarios Registrados</h5>
                </div>
                <div class="card-body">
                    @if (Model != null && Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>DNI</th>
                                        <th>Usuario</th>
                                        <th>Rol</th>
                                        <th>Estado</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var usuario in Model)
                                    {
                                        <tr>
                                            <td>@usuario.DNI</td>
                                            <td>@usuario.NombreUsuario</td>
                                            <td><span class="badge bg-secondary">@usuario.Rol</span></td>
                                            <td>
                                                @if (usuario.Activo)
                                                {
                                                    <span class="badge bg-success">Activo</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger">Inactivo</span>
                                                }
                                            </td>
                                            <td>
                                                <button type="button" class="btn btn-sm btn-outline-warning" onclick="cargarUsuario(@usuario.UsuarioId)">✏️</button>
                                                @if (usuario.Activo)
                                                {
                                                    <button type="button" class="btn btn-sm btn-outline-danger" onclick="desactivarUsuario(@usuario.UsuarioId)">🚫</button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info mb-0">
                            No hay usuarios registrados aún en la base de datos.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalMensaje" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalMensajeTitulo">Mensaje</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="modalMensajeContenido">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Entendido</button>
            </div>
        </div>
    </div>
</div>

<script>
    const formUsuario = document.getElementById('formUsuario');
    const btnBuscarDni = document.getElementById('btnBuscarDni');
    const inputDni = document.getElementById('DNI');
    const inputNombreUsuario = document.getElementById('NombreUsuario');
    const btnGuardar = document.getElementById('btnGuardar');
    const btnLimpiar = document.getElementById('btnLimpiar');

    // Evento: Buscar DNI
    btnBuscarDni.addEventListener('click', async function () {
        const dni = inputDni.value.trim();
        const textoOriginal = btnBuscarDni.innerHTML;

        if (!dni || dni.length !== 8 || !/^\d{8}$/.test(dni)) {
            mostrarAlerta('Validación', 'Por favor ingrese 8 dígitos numéricos válidos.');
            return;
        }

        btnBuscarDni.innerHTML = '⏳';
        btnBuscarDni.disabled = true;

        try {
            const response = await fetch(`/Admin/BuscarDni?dni=${dni}`);
            const data = await response.json();

            if (data.success) {
                // Concatenamos la respuesta del Mock directo al campo NombreUsuario
                const nombreCompleto = data.nombreCompleto || `${data.nombres} ${data.apellidos}`;
                inputNombreUsuario.value = nombreCompleto.trim();

                if (data.mensaje) {
                    mostrarAlerta('Aviso', data.mensaje);
                }
            } else {
                mostrarAlerta('Error', data.message || 'No se encontraron datos en RENIEC para este DNI.');
                inputNombreUsuario.value = '';
            }
        } catch (error) {
            console.error('Error al buscar DNI:', error);
            mostrarAlerta('Error', 'Error de red en la consulta al servidor.');
        } finally {
            btnBuscarDni.innerHTML = textoOriginal;
            btnBuscarDni.disabled = false;
        }
    });

    // Evento: Guardar Usuario vía AJAX
    btnGuardar.addEventListener('click', async function (e) {
        e.preventDefault();

        if (!formUsuario.checkValidity()) {
            formUsuario.reportValidity();
            return;
        }

        if (document.getElementById('Password').value !== document.getElementById('ConfirmPassword').value) {
            mostrarAlerta('Validación', 'Las contraseñas no coinciden. Verifíquelas.');
            return;
        }

        // El texto del botón cambia para indicar procesamiento
        const textoOriginal = btnGuardar.innerHTML;
        btnGuardar.innerHTML = 'Procesando...';
        btnGuardar.disabled = true;

        const formData = new FormData(formUsuario);
        const usuarioData = {
            DNI: formData.get('DNI'),
            NombreUsuario: formData.get('NombreUsuario'), // Ahora sí viajará con el dato correcto
            Password: formData.get('Password'),
            Rol: parseInt(formData.get('Rol')),
            Celular: formData.get('Celular'),
            Activo: document.getElementById('Activo').checked
        };

        try {
            const response = await fetch('/Admin/GuardarUsuario', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    // Si tienes AntiForgeryToken configurado, se debe enviar aquí
                },
                body: JSON.stringify(usuarioData)
            });

            const result = await response.json();

            if (result.success) {
                mostrarAlerta('Éxito', result.message || 'Usuario registrado exitosamente en el sistema.');
                formUsuario.reset();
                inputNombreUsuario.value = '';

                // Recargar para ver el usuario en la tabla
                setTimeout(() => location.reload(), 1500);
            } else {
                mostrarAlerta('Error', result.message || 'Ocurrió un error al guardar el usuario en la base de datos.');
            }
        } catch (error) {
            console.error('Error al guardar usuario:', error);
            mostrarAlerta('Error', 'No se pudo completar la operación de guardado.');
        } finally {
            btnGuardar.innerHTML = textoOriginal;
            btnGuardar.disabled = false;
        }
    });

    // Función auxiliar: Mostrar alerta en modal Bootstrap
    function mostrarAlerta(titulo, mensaje) {
        document.getElementById('modalMensajeTitulo').textContent = titulo;
        document.getElementById('modalMensajeContenido').textContent = mensaje;
        const modal = new bootstrap.Modal(document.getElementById('modalMensaje'));
        modal.show();
    }

    // Funciones en desarrollo (Próxima fase)
    function cargarUsuario(usuarioId) {
        mostrarAlerta('En desarrollo', 'La edición de usuarios estará disponible en el siguiente sprint.');
    }

    function desactivarUsuario(usuarioId) {
        mostrarAlerta('En desarrollo', 'La desactivación de usuarios estará disponible en el siguiente sprint.');
    }

    // Evento: Limpiar
    btnLimpiar.addEventListener('click', function () {
        inputNombreUsuario.value = '';
    });
</script>

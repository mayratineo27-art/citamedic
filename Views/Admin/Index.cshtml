        }

        // ============= CU12: AJUSTAR CUPOS =============

        function abrirAjusteCupos(programacionId, cuposActuales) {
            const nuevosCupos = prompt(
                `Ingresa los nuevos cupos (actual: ${cuposActuales}):\n\n(Mínimo: 1, Máximo: 100)`,
                cuposActuales.toString()
            );

            if (nuevosCupos === null) {
                return; // Usuario canceló
            }

            const cupos = parseInt(nuevosCupos);
            if (isNaN(cupos) || cupos < 1 || cupos > 100) {
                alert('Por favor ingresa un valor entre 1 y 100.');
                return;
            }

            ajustarCupos(programacionId, cupos);
        }

        async function ajustarCupos(programacionId, nuevosCupos) {
            try {
                const response = await fetch('/Admin/AjustarProgramacion', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ programacionId: programacionId, nuevosCupos: nuevosCupos })
                });

                const result = await response.json();

                if (result.success) {
                    alert(result.message);
                    setTimeout(() => location.reload(), 1000);
                } else {
                    alert(result.message || 'Error al ajustar cupos.');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Error en la solicitud.');
            }
        }
    </script>

@{
    ViewData["Title"] = "Panel de Administración — CITAMEDIC";
    var adminNombre = ViewBag.AdminNombre as string ?? "Administrador";
}

<!-- Google Fonts & FontAwesome (igual que Portal Paciente) -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<style>
    :root {
        --navy:             #1D2D50;
        --teal:             #2AAE8A;
        --teal-light:       #e8f7f3;
        --bg-main:          #f0f5f4;
        --text-main:        #1D2D50;
        --text-muted:       #64748b;
        --border:           #e2e8f0;
        --radius:           24px;
        --shadow-sm:        0 4px 6px -1px rgba(29,45,80,0.02), 0 2px 4px -2px rgba(29,45,80,0.02);
        --shadow-md:        0 10px 15px -3px rgba(29,45,80,0.05), 0 4px 6px -4px rgba(29,45,80,0.04);
        --hero-start:       #1D2D50;
        --hero-end:         #0f1e38;
    }

    body {
        font-family: 'Plus Jakarta Sans', 'Inter', sans-serif;
        background-color: var(--bg-main);
        color: var(--text-main);
    }

    /* ── PAGE WRAPPER ────────────────────────────── */
    .admin-page {
        min-height: 100vh;
        padding: 2.5rem 3rem;
        max-width: 1400px;
        margin: 0 auto;
    }

    /* ── HEADER DE BIENVENIDA ────────────────────── */
    .admin-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 2.5rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .welcome-title {
        font-family: 'Outfit', sans-serif;
        font-weight: 400;
        font-size: 2.35rem;
        color: var(--navy);
        margin: 0 0 0.25rem 0;
        line-height: 1.15;
    }

    .welcome-subtitle {
        color: var(--text-muted);
        font-size: 1rem;
        margin: 0;
    }

    .admin-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        background: #ffffff;
        border: 1px solid var(--border);
        border-radius: 9999px;
        padding: 0.5rem 1.25rem;
        box-shadow: var(--shadow-sm);
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--navy);
    }

    .admin-badge-dot {
        width: 8px;
        height: 8px;
        background: var(--teal);
        border-radius: 50%;
        animation: pulse-dot 1.6s infinite ease-out;
    }

    @@keyframes pulse-dot {
        0%   { box-shadow: 0 0 0 0   rgba(42,174,138,0.5); }
        70%  { box-shadow: 0 0 0 8px rgba(42,174,138,0); }
        100% { box-shadow: 0 0 0 0   rgba(42,174,138,0); }
    }

    /* ── HERO BANNER ─────────────────────────────── */
    .hero-banner {
        background: linear-gradient(135deg, var(--hero-start) 0%, var(--hero-end) 100%);
        border-radius: var(--radius);
        padding: 2.5rem 3rem;
        margin-bottom: 2rem;
        position: relative;
        overflow: hidden;
        color: white;
        box-shadow: 0 10px 30px rgba(29,45,80,0.15);
    }

    .hero-banner::before {
        content: '';
        position: absolute;
        width: 320px; height: 320px;
        background: rgba(255,255,255,0.03);
        border-radius: 50%;
        top: -80px; right: -80px;
    }

    .hero-banner::after {
        content: '';
        position: absolute;
        width: 200px; height: 200px;
        background: rgba(42,174,138,0.08);
        border-radius: 50%;
        bottom: -60px; left: -40px;
    }

    .hero-logo {
        width: 52px; height: 52px;
        background: rgba(42,174,138,0.2);
        border: 1px solid rgba(42,174,138,0.35);
        border-radius: 16px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.5rem;
        margin-bottom: 1.25rem;
        position: relative; z-index: 2;
    }

    .hero-title {
        font-family: 'Outfit', sans-serif;
        font-size: 1.65rem;
        font-weight: 700;
        margin-bottom: 0.4rem;
        position: relative; z-index: 2;
    }

    .hero-subtitle {
        font-size: 0.95rem;
        opacity: 0.75;
        max-width: 560px;
        position: relative; z-index: 2;
    }

    .hero-stats {
        display: flex;
        gap: 2rem;
        margin-top: 1.75rem;
        position: relative; z-index: 2;
        flex-wrap: wrap;
    }

    .hero-stat {
        display: flex;
        flex-direction: column;
    }

    .hero-stat-value {
        font-family: 'Outfit', sans-serif;
        font-size: 1.65rem;
        font-weight: 800;
        color: #2AAE8A;
        line-height: 1;
    }

    .hero-stat-label {
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        opacity: 0.6;
        margin-top: 4px;
    }

    .hero-ghost-icon {
        position: absolute;
        right: -30px;
        bottom: -40px;
        font-size: 16rem;
        color: rgba(255,255,255,0.025);
        pointer-events: none;
        transform: rotate(-12deg);
        z-index: 1;
    }

    /* ── SECTION LABEL ───────────────────────────── */
    .section-label {
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--text-muted);
        margin-bottom: 1rem;
    }

    /* ── MODULE CARDS ────────────────────────────── */
    .module-card {
        background: #ffffff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.75rem 1.5rem;
        box-shadow: var(--shadow-sm);
        transition: all 0.22s ease;
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .module-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-md);
        border-color: rgba(42,174,138,0.3);
        text-decoration: none;
        color: inherit;
    }

    .module-card:hover .module-arrow {
        transform: translateX(4px);
        color: var(--teal);
    }

    .module-icon-wrap {
        width: 52px; height: 52px;
        border-radius: 14px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem;
        margin-bottom: 1.1rem;
        flex-shrink: 0;
    }

    .module-title {
        font-family: 'Outfit', sans-serif;
        font-weight: 700;
        font-size: 1.05rem;
        color: var(--navy);
        margin-bottom: 0.4rem;
    }

    .module-desc {
        font-size: 0.85rem;
        color: var(--text-muted);
        line-height: 1.55;
        flex-grow: 1;
    }

    .module-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 1.1rem;
        padding-top: 1rem;
        border-top: 1px solid var(--border);
    }

    .module-tag {
        font-size: 0.68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 0.25rem 0.6rem;
        border-radius: 9999px;
    }

    .module-arrow {
        font-size: 0.8rem;
        color: var(--text-muted);
        transition: all 0.2s ease;
    }

    /* ── ALERT SUCCESS ───────────────────────────── */
    .alert-admin-success {
        background: #f0fdf9;
        border: 1px solid rgba(42,174,138,0.2);
        border-radius: 14px;
        padding: 1rem 1.25rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: #0f766e;
        font-weight: 600;
        font-size: 0.9rem;
        margin-bottom: 1.75rem;
    }

    /* ── RESPONSIVE ──────────────────────────────── */
    @@media (max-width: 768px) {
        .admin-page    { padding: 1.5rem 1.25rem; }
        .hero-banner   { padding: 1.75rem 1.5rem; }
        .welcome-title { font-size: 1.75rem; }
        .hero-title    { font-size: 1.3rem; }
    }
</style>

<div class="admin-page">

    <!-- ═══ HEADER ═══════════════════════════════════════════ -->
    <header class="admin-header">
        <div>
            <h1 class="welcome-title" id="admin-greeting">
                Hola, <span style="color:#2AAE8A; font-weight:700;">@adminNombre</span> 👋
            </h1>
            <p class="welcome-subtitle">Panel de Administración — Posta de Salud Los Licenciados</p>
        </div>
        <div class="admin-badge">
            <span class="admin-badge-dot"></span>
            <i class="fa-solid fa-shield-halved" style="color:var(--teal);"></i>
            Sesión Activa
        </div>
    </header>

    <!-- ═══ ALERT DE ÉXITO ════════════════════════════════════ -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-admin-success">
            <i class="fa-solid fa-circle-check fa-lg"></i>
            <span>@TempData["SuccessMessage"]</span>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" style="font-size:0.75rem;"></button>
        </div>
    }

    <!-- ═══ HERO BANNER ═══════════════════════════════════════ -->
    <div class="hero-banner mb-4">
        <div class="hero-logo">
            <i class="fa-solid fa-plus text-white"></i>
        </div>
        <h2 class="hero-title">Sistema de Gestión CITAMEDIC</h2>
        <p class="hero-subtitle">Administra los módulos del sistema desde un único panel. Configura usuarios, especialidades, médicos y programaciones operativas.</p>

        <div class="hero-stats">
            <div class="hero-stat">
                <span class="hero-stat-value">6</span>
                <span class="hero-stat-label">Módulos activos</span>
            </div>
            <div class="hero-stat">
                <span class="hero-stat-value">v1.0</span>
                <span class="hero-stat-label">Versión del sistema</span>
            </div>
            <div class="hero-stat">
                <span class="hero-stat-value">SpecDD</span>
                <span class="hero-stat-label">Metodología</span>
            </div>
        </div>

        <i class="fa-solid fa-hospital hero-ghost-icon"></i>
    </div>

    <!-- ═══ MÓDULOS ═══════════════════════════════════════════ -->
    <div class="section-label">Módulos del Sistema</div>

    <div class="row g-4">

        <!-- Gestión de Usuarios -->
        <div class="col-md-6 col-lg-4">
            <a href="@Url.Action("Usuarios", "Admin")" class="module-card">
                <div class="module-icon-wrap" style="background:#e0e7ff;">
                    <i class="fa-solid fa-users-gear" style="color:#4f46e5;"></i>
                </div>
                <div class="module-title">Gestión de Usuarios</div>
                <div class="module-desc">Administrar cuentas de pacientes, enfermería y admisión. Control de roles y acceso al sistema (CU18 / RF22).</div>
                <div class="module-footer">
                    <span class="module-tag" style="background:#e0e7ff; color:#4f46e5;">Usuarios</span>
                    <i class="fa-solid fa-arrow-right module-arrow"></i>
                </div>
            </a>
        </div>

        <!-- Padrón de Pacientes -->
        <div class="col-md-6 col-lg-4">
            <a href="@Url.Action("Pacientes", "Admin")" class="module-card">
                <div class="module-icon-wrap" style="background:#f0fdf9;">
                    <i class="fa-solid fa-id-card-clip" style="color:#2AAE8A;"></i>
                </div>
                <div class="module-title">Padrón de Pacientes</div>
                <div class="module-desc">Visualizar el directorio de pacientes registrados, seguros SIS y menores de edad con su responsable asignado.</div>
                <div class="module-footer">
                    <span class="module-tag" style="background:#f0fdf9; color:#2AAE8A;">Pacientes</span>
                    <i class="fa-solid fa-arrow-right module-arrow"></i>
                </div>
            </a>
        </div>

        <!-- Unidades UPS -->
        <div class="col-md-6 col-lg-4">
            <a href="@Url.Action("UPS", "Admin")" class="module-card">
                <div class="module-icon-wrap" style="background:#fff7ed;">
                    <i class="fa-solid fa-building-columns" style="color:#ea580c;"></i>
                </div>
                <div class="module-title">Unidades (UPS)</div>
                <div class="module-desc">Crear, editar y desactivar Unidades Productoras de Servicios de Salud vinculadas a especialidades.</div>
                <div class="module-footer">
                    <span class="module-tag" style="background:#fff7ed; color:#ea580c;">Infraestructura</span>
                    <i class="fa-solid fa-arrow-right module-arrow"></i>
                </div>
            </a>
        </div>

        <!-- Especialidades -->
        <div class="col-md-6 col-lg-4">
            <a href="@Url.Action("Especialidades", "Admin")" class="module-card">
                <div class="module-icon-wrap" style="background:#fdf4ff;">
                    <i class="fa-solid fa-stethoscope" style="color:#9333ea;"></i>
                </div>
                <div class="module-title">Especialidades</div>
                <div class="module-desc">Configurar nombres, UPS asignada y duración base de atención por especialidad médica disponible.</div>
                <div class="module-footer">
                    <span class="module-tag" style="background:#fdf4ff; color:#9333ea;">Clínico</span>
                    <i class="fa-solid fa-arrow-right module-arrow"></i>
                </div>
            </a>
        </div>

        <!-- Personal Médico -->
        <div class="col-md-6 col-lg-4">
            <a href="@Url.Action("Medicos", "Admin")" class="module-card">
                <div class="module-icon-wrap" style="background:#fff1f2;">
                    <i class="fa-solid fa-user-doctor" style="color:#e11d48;"></i>
                </div>
                <div class="module-title">Personal Médico</div>
                <div class="module-desc">Administrar el registro de médicos activos, datos personales y número de colegiatura (CMP).</div>
                <div class="module-footer">
                    <span class="module-tag" style="background:#fff1f2; color:#e11d48;">Médicos</span>
                    <i class="fa-solid fa-arrow-right module-arrow"></i>
                </div>
            </a>
        </div>

        <!-- Programación Operativa -->
        <div class="col-md-6 col-lg-4">
            <a href="@Url.Action("Programacion", "Admin")" class="module-card">
                <div class="module-icon-wrap" style="background:#fffbeb;">
                    <i class="fa-solid fa-calendar-days" style="color:#d97706;"></i>
                </div>
                <div class="module-title">Programación Operativa</div>
                <div class="module-desc">Configurar turnos, fechas, cupos y habilitar disponibilidades para la atención diaria de pacientes.</div>
                <div class="module-footer">
                    <span class="module-tag" style="background:#fffbeb; color:#d97706;">Agenda</span>
                    <i class="fa-solid fa-arrow-right module-arrow"></i>
                </div>
            </a>
        </div>

    </div><!-- /row -->

    <!-- ═══ FOOTER DISCLAIMER ════════════════════════════════ -->
    <div class="text-center mt-5 pt-4" style="border-top:1px solid var(--border); font-size:0.72rem; color:var(--text-muted);">
        <strong>PostaCitasWeb v1.0</strong> — Sistema Spec-Driven Development (SpecDD) ·
        Solo personal autorizado con rol <strong>Administrador</strong> tiene acceso a este panel.
    </div>

</div><!-- /admin-page -->

@section Scripts {
    <script>
        // Saludo dinámico según hora
        (function () {
            const hour = new Date().getHours();
            const name = "@adminNombre";
            let word = "Hola";
            if (hour >= 6  && hour < 12) word = "Buenos días";
            else if (hour >= 12 && hour < 19) word = "Buenas tardes";
            else word = "Buenas noches";
            document.getElementById('admin-greeting').innerHTML =
                `${word}, <span style="color:#2AAE8A;font-weight:700;">${name}</span> 👋`;
        })();
    </script>
}
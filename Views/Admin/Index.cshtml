@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Panel del Administrador";
}

<div class="container py-4">
    <div class="card shadow-sm mb-4">
        <div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <h1 class="h3 mb-1">Panel del Administrador</h1>
                <p class="text-muted mb-0">Configuración de estructura operativa, usuarios, especialidades y duración de atención.</p>
            </div>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Gestionar Usuarios</h5>
                    <p class="card-text">Administrar pacientes, enfermería y admisión según CU18 y RF22.</p>
                    <div class="d-flex gap-2 flex-wrap">
                        <a href="#usuarios" class="btn btn-primary btn-sm">Buscar</a>
                        <a href="#usuarios" class="btn btn-outline-secondary btn-sm">Editar</a>
                        <a href="#usuarios" class="btn btn-outline-danger btn-sm">Guardar</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Gestionar UPS</h5>
                    <p class="card-text">Crear, editar y desactivar UPS. Las UPS son internas y no visibles para pacientes.</p>
                    <div class="d-flex gap-2 flex-wrap">
                        <a href="#ups" class="btn btn-primary btn-sm">Crear</a>
                        <a href="#ups" class="btn btn-outline-secondary btn-sm">Editar</a>
                        <a href="#ups" class="btn btn-outline-danger btn-sm">Desactivar</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Gestionar Especialidades</h5>
                    <p class="card-text">Configurar nombre, UPS y duración de atención según RF14 y RF23.</p>
                    <div class="d-flex gap-2 flex-wrap">
                        <a href="#especialidades" class="btn btn-primary btn-sm">Crear</a>
                        <a href="#especialidades" class="btn btn-outline-secondary btn-sm">Editar</a>
                        <a href="#especialidades" class="btn btn-outline-danger btn-sm">Desactivar</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Programación Operativa</h5>
                    <p class="card-text">Configurar programación futura con especialidad, médico, turno, duración y cupos.</p>
                    <div class="d-flex gap-2 flex-wrap">
                        <a href="#programacion" class="btn btn-primary btn-sm">Configurar</a>
                        <a href="#programacion" class="btn btn-outline-secondary btn-sm">Publicar</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Duración de Atención</h5>
                    <p class="card-text">Definir la duración por especialidad para el cálculo de cupos y tarjetas.</p>
                    <div class="d-flex gap-2 flex-wrap">
                        <a href="#duracion" class="btn btn-primary btn-sm">Configurar</a>
                        <a href="#duracion" class="btn btn-outline-secondary btn-sm">Actualizar</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Resumen del alcance</h5>
                    <ul class="list-unstyled mb-0 text-muted">
                        <li>• CU10 - Configurar programación operativa</li>
                        <li>• CU18 - Gestionar usuarios</li>
                        <li>• CU19 - Configurar duración de atención</li>
                        <li>• RF13, RF14, RF15A, RF22, RF23</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-2">
        <div class="col-lg-6" id="usuarios">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <strong>Usuarios internos</strong>
                </div>
                <div class="card-body">
                    <form id="formUsuarioIndex" class="mb-3">
                        <h6>Crear Usuario</h6>

                        <!-- Input Group: DNI con botón Buscar -->
                        <div class="mb-2">
                            <label for="DNI" class="form-label">DNI</label>
                            <div class="input-group input-group-sm">
                                <input 
                                    type="text" 
                                    class="form-control" 
                                    id="DNI" 
                                    name="DNI" 
                                    maxlength="8" 
                                    placeholder="8 dígitos"
                                    required>
                                <button 
                                    type="button" 
                                    class="btn btn-primary" 
                                    id="btnBuscarDni">Buscar</button>
                            </div>
                        </div>

                        <!-- Campos Nombres y Apellidos (readonly) -->
                        <div class="mb-2">
                            <label for="Nombres" class="form-label">Nombres</label>
                            <input 
                                type="text" 
                                class="form-control form-control-sm" 
                                id="Nombres" 
                                name="Nombres" 
                                readonly>
                        </div>

                        <div class="mb-2">
                            <label for="Apellidos" class="form-label">Apellidos</label>
                            <input 
                                type="text" 
                                class="form-control form-control-sm" 
                                id="Apellidos" 
                                name="Apellidos" 
                                readonly>
                        </div>

                        <div class="mb-2">
                            <label for="NombreUsuario" class="form-label">Nombre Usuario</label>
                            <input type="text" class="form-control form-control-sm" id="NombreUsuario" name="NombreUsuario" required>
                        </div>
                        <div class="mb-2">
                            <label for="Password" class="form-label">Contraseña</label>
                            <input type="password" class="form-control form-control-sm" id="Password" name="Password" required>
                        </div>
                        <div class="mb-2">
                            <label for="ConfirmPassword" class="form-label">Confirmar Contraseña</label>
                            <input type="password" class="form-control form-control-sm" id="ConfirmPassword" name="ConfirmPassword" required>
                        </div>
                        <div class="mb-2">
                            <label for="Rol" class="form-label">Rol</label>
                            <select class="form-select form-select-sm" id="Rol" name="Rol" required>
                                <option value="">Seleccione un rol</option>
                                <option value="0">Paciente</option>
                                <option value="1">Admisión</option>
                                <option value="2">Enfermería</option>
                                <option value="3">Administrador</option>
                                <option value="4">Médico</option>
                            </select>
                        </div>
                        <div class="mb-2">
                            <label for="Celular" class="form-label">Celular</label>
                            <input type="text" class="form-control form-control-sm" id="Celular" name="Celular" required>
                        </div>
                        <button type="button" class="btn btn-primary btn-sm" id="btnGuardarUsuario">Crear Usuario</button>
                    </form>

                    @if (Model.Usuarios.Any())
                    {
                        <div class="table-responsive mt-3">
                            <table class="table table-sm table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>DNI</th>
                                        <th>Usuario</th>
                                        <th>Rol</th>
                                        <th>Celular</th>
                                        <th>Estado</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var usuario in Model.Usuarios)
                                    {
                                        <tr>
                                            <td>@usuario.DNI</td>
                                            <td>@usuario.NombreUsuario</td>
                                            <td>@usuario.Rol</td>
                                            <td>@usuario.Celular</td>
                                            <td>
                                                @if (usuario.Activo)
                                                {
                                                    <span class="badge bg-success">Activo</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger">Inactivo</span>
                                                }
                                            </td>
                                            <td>
                                                @if (usuario.Activo)
                                                {
                                                    <form method="post" asp-action="DeleteUsuario" style="display:inline;">
                                                        <input type="hidden" name="id" value="@usuario.UsuarioId">
                                                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('¿Desactivar este usuario?')">Desactivar</button>
                                                    </form>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-6" id="especialidades">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <strong>Especialidades</strong>
                </div>
                <div class="card-body">
                    <form method="post" asp-action="CreateEspecialidad" class="mb-3">
                        <div class="mb-3">
                            <label for="especialidadNombre" class="form-label">Nombre de la Especialidad</label>
                            <input type="text" class="form-control" id="especialidadNombre" name="Nombre" required>
                        </div>
                        <div class="mb-3">
                            <label for="especialidadUPS" class="form-label">UPS</label>
                            <select class="form-select" id="especialidadUPS" name="UPSId" required>
                                <option value="">Seleccione una UPS</option>
                                @foreach (var ups in Model.UPS)
                                {
                                    @if (ups.Activa)
                                    {
                                        <option value="@ups.UPSId">@ups.Nombre</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="especialidadDuracion" class="form-label">Duración (minutos)</label>
                            <input type="number" class="form-control" id="especialidadDuracion" name="DuracionMinutos" min="1" max="480" required>
                        </div>
                        <button type="submit" class="btn btn-primary btn-sm">Crear Especialidad</button>
                    </form>

                    @if (Model.Especialidades.Any())
                    {
                        <div class="table-responsive mt-4">
                            <table class="table table-sm table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>Nombre</th>
                                        <th>UPS</th>
                                        <th>Duración (min)</th>
                                        <th>Estado</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var espec in Model.Especialidades)
                                    {
                                        <tr>
                                            <td>@espec.Nombre</td>
                                            <td>@espec.UPSNombre</td>
                                            <td>@espec.DuracionMinutos</td>
                                            <td>
                                                @if (espec.Activa)
                                                {
                                                    <span class="badge bg-success">Activa</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger">Inactiva</span>
                                                }
                                            </td>
                                            <td>
                                                @if (espec.Activa)
                                                {
                                                    <button type="button" class="btn btn-sm btn-warning" data-bs-toggle="modal" data-bs-target="#editEspecialidadModal" onclick="loadEspecialidadData(@espec.EspecialidadId, '@espec.Nombre', @espec.DuracionMinutos)">Editar</button>
                                                    <form method="post" asp-action="DeleteEspecialidad" style="display:inline;">
                                                        <input type="hidden" name="id" value="@espec.EspecialidadId">
                                                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('¿Desactivar esta especialidad?')">Desactivar</button>
                                                    </form>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-6" id="ups">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <strong>UPS</strong>
                </div>
                <div class="card-body">
                    <form method="post" asp-action="CreateUPS" class="mb-3">
                        <div class="mb-3">
                            <label for="upsNombre" class="form-label">Nombre de la UPS</label>
                            <input type="text" class="form-control" id="upsNombre" name="Nombre" required>
                        </div>
                        <button type="submit" class="btn btn-primary btn-sm">Crear UPS</button>
                    </form>

                    @if (Model.UPS.Any())
                    {
                        <div class="table-responsive mt-4">
                            <table class="table table-sm table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>Nombre</th>
                                        <th>Estado</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ups in Model.UPS)
                                    {
                                        <tr>
                                            <td>@ups.Nombre</td>
                                            <td>
                                                @if (ups.Activa)
                                                {
                                                    <span class="badge bg-success">Activa</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger">Inactiva</span>
                                                }
                                            </td>
                                            <td>
                                                @if (ups.Activa)
                                                {
                                                    <button type="button" class="btn btn-sm btn-warning" data-bs-toggle="modal" data-bs-target="#editUPSModal" onclick="loadUPSData(@ups.UPSId, '@ups.Nombre')">Editar</button>
                                                    <form method="post" asp-action="DeleteUPS" style="display:inline;">
                                                        <input type="hidden" name="id" value="@ups.UPSId">
                                                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('¿Desactivar esta UPS?')">Desactivar</button>
                                                    </form>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-6" id="programacion">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <strong>Médicos</strong>
                </div>
                <div class="card-body">
                    <form method="post" asp-action="CreateMedico" class="mb-3">
                        <h6>Crear Médico</h6>
                        <div class="mb-2">
                            <label for="medicoNombres" class="form-label">Nombres</label>
                            <input type="text" class="form-control form-control-sm" id="medicoNombres" name="Nombres" required>
                        </div>
                        <div class="mb-2">
                            <label for="medicoApellidoP" class="form-label">Apellido Paterno</label>
                            <input type="text" class="form-control form-control-sm" id="medicoApellidoP" name="ApellidoPaterno" required>
                        </div>
                        <div class="mb-2">
                            <label for="medicoApellidoM" class="form-label">Apellido Materno</label>
                            <input type="text" class="form-control form-control-sm" id="medicoApellidoM" name="ApellidoMaterno">
                        </div>
                        <div class="mb-2">
                            <label for="medicoCMP" class="form-label">CMP</label>
                            <input type="text" class="form-control form-control-sm" id="medicoCMP" name="CMP" required>
                        </div>
                        <button type="submit" class="btn btn-primary btn-sm">Crear Médico</button>
                    </form>

                    @if (Model.Medicos.Any())
                    {
                        <div class="table-responsive mt-3">
                            <table class="table table-sm table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>Nombres</th>
                                        <th>Apellidos</th>
                                        <th>CMP</th>
                                        <th>Estado</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var medico in Model.Medicos)
                                    {
                                        <tr>
                                            <td>@medico.Nombres</td>
                                            <td>@medico.ApellidoPaterno @medico.ApellidoMaterno</td>
                                            <td>@medico.CMP</td>
                                            <td>
                                                @if (medico.Activo)
                                                {
                                                    <span class="badge bg-success">Activo</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger">Inactivo</span>
                                                }
                                            </td>
                                            <td>
                                                @if (medico.Activo)
                                                {
                                                    <form method="post" asp-action="DeleteMedico" style="display:inline;">
                                                        <input type="hidden" name="id" value="@medico.MedicoId">
                                                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('¿Desactivar este médico?')">Desactivar</button>
                                                    </form>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-12" id="duracion">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <strong>Programación operativa</strong>
                </div>
                <div class="card-body">
                    <form method="post" asp-action="CreateProgramacion" class="mb-3">
                        <div class="row">
                            <div class="col-md-6 mb-2">
                                <label for="progEspecialidad" class="form-label">Especialidad</label>
                                <select class="form-select form-select-sm" id="progEspecialidad" name="EspecialidadId" required>
                                    <option value="">Seleccione especialidad</option>
                                    @foreach (var espec in Model.Especialidades.Where(e => e.Activa))
                                    {
                                        <option value="@espec.EspecialidadId">@espec.Nombre</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6 mb-2">
                                <label for="progMedico" class="form-label">Médico</label>
                                <select class="form-select form-select-sm" id="progMedico" name="MedicoId" required>
                                    <option value="">Seleccione médico</option>
                                    @foreach (var medico in Model.Medicos.Where(m => m.Activo))
                                    {
                                        <option value="@medico.MedicoId">@medico.NombreCompleto</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-3 mb-2">
                                <label for="progTurno" class="form-label">Turno</label>
                                <select class="form-select form-select-sm" id="progTurno" name="Turno" required>
                                    <option value="0">Mañana</option>
                                    <option value="1">Tarde</option>
                                </select>
                            </div>
                            <div class="col-md-3 mb-2">
                                <label for="progFecha" class="form-label">Fecha</label>
                                <input type="date" class="form-control form-control-sm" id="progFecha" name="Fecha" required>
                            </div>
                            <div class="col-md-3 mb-2">
                                <label for="progCupos" class="form-label">Cupos</label>
                                <input type="number" class="form-control form-control-sm" id="progCupos" name="CuposTotal" min="1" max="100" required>
                            </div>
                            <div class="col-md-3 mb-2">
                                <label for="progDuracion" class="form-label">Duración (min)</label>
                                <input type="number" class="form-control form-control-sm" id="progDuracion" name="DuracionMinutos" min="1" max="480" required>
                            </div>
                        </div>
                        <div class="mb-2">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="progHabilitada" name="Habilitada" value="true">
                                <label class="form-check-label" for="progHabilitada">
                                    Habilitar programación
                                </label>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary btn-sm">Crear Programación</button>
                    </form>

                    @if (Model.ProgramacionesOperativas.Any())
                    {
                        <div class="table-responsive mt-3">
                            <table class="table table-sm table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>Especialidad</th>
                                        <th>Médico</th>
                                        <th>Turno</th>
                                        <th>Fecha</th>
                                        <th>Cupos</th>
                                        <th>Duración</th>
                                        <th>Estado</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var prog in Model.ProgramacionesOperativas)
                                    {
                                        <tr>
                                            <td>@prog.EspecialidadNombre</td>
                                            <td>@prog.MedicoNombre</td>
                                            <td>@prog.Turno</td>
                                            <td>@prog.Fecha</td>
                                            <td>@prog.CuposTotal</td>
                                            <td>@prog.DuracionMinutos</td>
                                            <td>
                                                @if (prog.Habilitada)
                                                {
                                                    <span class="badge bg-success">Habilitada</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger">Deshabilitada</span>
                                                }
                                            </td>
                                            <td>
                                                @if (!prog.Habilitada)
                                                {
                                                    <button type="button" class="btn btn-sm btn-success" onclick="habilitarProgramacion(@prog.ProgramacionId_Key)">Habilitar</button>
                                                }
                                                else
                                                {
                                                    <button type="button" class="btn btn-sm btn-warning" onclick="deshabilitarProgramacion(@prog.ProgramacionId_Key)">Desabilitar</button>
                                                }
                                                <button type="button" class="btn btn-sm btn-info" onclick="abrirAjusteCupos(@prog.ProgramacionId_Key, @prog.CuposTotal)">Ajustar</button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
    <script>
        function loadUPSData(id, nombre) {
            document.getElementById('editUPSId').value = id;
            document.getElementById('editUPSNombre').value = nombre;
        }

        function loadEspecialidadData(id, nombre, duracion) {
            document.getElementById('editEspecialidadId').value = id;
            document.getElementById('editEspecialidadNombre').value = nombre;
            document.getElementById('editEspecialidadDuracion').value = duracion;
        }

        // ============= CU18: GESTIONAR USUARIOS =============

        const btnBuscarDni = document.getElementById('btnBuscarDni');
        const inputDni = document.getElementById('DNI');
        const inputNombres = document.getElementById('Nombres');
        const inputApellidos = document.getElementById('Apellidos');
        const formUsuario = document.getElementById('formUsuarioIndex');
        const btnGuardarUsuario = document.getElementById('btnGuardarUsuario');

        // Evento: Buscar DNI
        btnBuscarDni.addEventListener('click', async function () {
            const dni = inputDni.value.trim();

            // Validar que sea 8 dígitos numéricos
            if (!dni || dni.length !== 8 || !/^\d{8}$/.test(dni)) {
                alert('Por favor ingrese 8 dígitos numéricos válidos.');
                return;
            }

            try {
                const response = await fetch(`/Admin/BuscarDni?dni=${dni}`);
                const data = await response.json();

                if (data.success) {
                    // Asignar valores
                    inputNombres.value = data.nombres || '';
                    inputApellidos.value = data.apellidos || '';
                } else {
                    alert(data.message || 'No se encontraron datos para este DNI.');
                    inputNombres.value = '';
                    inputApellidos.value = '';
                }
            } catch (error) {
                console.error('Error al buscar DNI:', error);
                alert('Error en la consulta. Intente nuevamente.');
            }
        });

        // Evento: Guardar Usuario
        btnGuardarUsuario.addEventListener('click', async function (e) {
            e.preventDefault();

            // Validar que los campos obligatorios estén llenos
            if (!formUsuario.checkValidity()) {
                formUsuario.reportValidity();
                return;
            }

            // Validar contraseñas coincidan
            if (document.getElementById('Password').value !== document.getElementById('ConfirmPassword').value) {
                alert('Las contraseñas no coinciden.');
                return;
            }

            const usuarioData = {
                DNI: document.getElementById('DNI').value,
                NombreUsuario: document.getElementById('NombreUsuario').value,
                Password: document.getElementById('Password').value,
                ConfirmPassword: document.getElementById('ConfirmPassword').value,
                Rol: parseInt(document.getElementById('Rol').value),
                Celular: document.getElementById('Celular').value,
                Activo: true
            };

            try {
                const response = await fetch('/Admin/GuardarUsuario', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(usuarioData)
                });

                const result = await response.json();

                if (result.success) {
                    alert(result.message || 'Usuario guardado exitosamente.');
                    formUsuario.reset();
                    inputNombres.value = '';
                    inputApellidos.value = '';
                    // Recargar la página después de 1 segundo
                    setTimeout(() => location.reload(), 1000);
                } else {
                    alert(result.message || 'Error al guardar el usuario.');
                }
            } catch (error) {
                console.error('Error al guardar usuario:', error);
                alert('Error en la solicitud. Intente nuevamente.');
            }
        });

        // ============= CU11: HABILITAR PROGRAMACIÓN =============

        async function habilitarProgramacion(programacionId) {
            if (!confirm('¿Deseas habilitar esta programación?\nLos pacientes podrán ver y reservar citas.')) {
                return;
            }

            try {
                const response = await fetch('/Admin/HabilitarProgramacion', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ id: programacionId })
                });

                const result = await response.json();

                if (result.success) {
                    alert(result.message);
                    setTimeout(() => location.reload(), 1000);
                } else {
                    alert(result.message || 'Error al habilitar programación.');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Error en la solicitud.');
            }
        }


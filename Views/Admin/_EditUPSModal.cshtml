@model AdminDashboardViewModel

<div class="modal fade" id="editUPSModal" tabindex="-1" aria-labelledby="editUPSModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editUPSModalLabel">Editar UPS</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-action="UpdateUPS">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="editUPSId" class="form-label">ID</label>
                        <input type="number" class="form-control" id="editUPSId" name="upsId" readonly>
                    </div>
                    <div class="mb-3">
                        <label for="editUPSNombre" class="form-label">Nombre</label>
                        <input type="text" class="form-control" id="editUPSNombre" name="nombre" required>
                    </div>
                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" id="editUPSActiva" name="activa" value="true" checked>
                        <label class="form-check-label" for="editUPSActiva">UPS Activa</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Guardar cambios</button>
                </div>
            </form>
        </div>
    </div>
</div>

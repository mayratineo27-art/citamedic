@model PostaCitasWeb.Models.ViewModels.EnfermeriaDashboardViewModel
@{
    ViewData["Title"] = "Panel de Enfermería — CITAMEDIC";
    var nombre = ViewBag.EnfermeraNombre as string ?? "Enfermera";
    var totalEspera = Model.CitasEnEspera.Count(c => c.EstadoCita == PostaCitasWeb.Entities.EstadoCita.Pendiente || c.EstadoCita == PostaCitasWeb.Entities.EstadoCita.EnTriaje);
    var totalAvisos = Model.AvisosPendientes.Count();
}

<!-- Fuentes y FontAwesome -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<style>
    :root {
        --navy:        #1D2D50;
        --teal:        #2AAE8A;
        --teal-light:  #e8f7f3;
        --rose:        #e11d48;
        --rose-light:  #fff1f2;
        --amber:       #d97706;
        --amber-light: #fffbeb;
        --bg-main:     #f0f5f4;
        --text-main:   #1D2D50;
        --text-muted:  #64748b;
        --border:      #e2e8f0;
        --radius:      24px;
        --shadow-sm:   0 4px 6px -1px rgba(29,45,80,0.02), 0 2px 4px -2px rgba(29,45,80,0.02);
        --shadow-md:   0 10px 15px -3px rgba(29,45,80,0.05), 0 4px 6px -4px rgba(29,45,80,0.04);
    }

    body { font-family: 'Plus Jakarta Sans', 'Inter', sans-serif; background: var(--bg-main); color: var(--text-main); }

    .enf-page { min-height: 100vh; padding: 2.5rem 3rem; max-width: 1300px; margin: 0 auto; }

    /* Header */
    .enf-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 2.5rem; flex-wrap: wrap; gap: 1rem; }
    .welcome-title { font-family: 'Outfit', sans-serif; font-weight: 400; font-size: 2.35rem; color: var(--navy); margin: 0 0 0.25rem; line-height: 1.15; }
    .welcome-subtitle { color: var(--text-muted); font-size: 1rem; margin: 0; }

    .status-badge {
        display: inline-flex; align-items: center; gap: 0.6rem;
        background: #fff; border: 1px solid var(--border);
        border-radius: 9999px; padding: 0.5rem 1.25rem;
        box-shadow: var(--shadow-sm); font-size: 0.85rem; font-weight: 600; color: var(--navy);
    }
    .badge-dot {
        width: 8px; height: 8px; background: var(--rose); border-radius: 50%;
        animation: pulse-dot 1.4s infinite ease-out;
    }
    @@keyframes pulse-dot {
        0%  { box-shadow: 0 0 0 0   rgba(225,29,72,0.5); }
        70% { box-shadow: 0 0 0 8px rgba(225,29,72,0); }
        100%{ box-shadow: 0 0 0 0   rgba(225,29,72,0); }
    }

    /* Hero */
    .hero-banner {
        background: linear-gradient(135deg, #be123c 0%, #881337 100%);
        border-radius: var(--radius); padding: 2.25rem 3rem; margin-bottom: 2rem;
        position: relative; overflow: hidden; color: white;
        box-shadow: 0 10px 30px rgba(190,18,60,0.18);
    }
    .hero-banner::before {
        content:''; position: absolute; width: 280px; height: 280px;
        background: rgba(255,255,255,0.04); border-radius: 50%;
        top: -70px; right: -70px;
    }
    .hero-logo {
        width: 50px; height: 50px; background: rgba(255,255,255,0.15);
        border: 1px solid rgba(255,255,255,0.25); border-radius: 14px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.35rem; margin-bottom: 1.1rem; position: relative; z-index: 2;
    }
    .hero-title { font-family: 'Outfit', sans-serif; font-size: 1.5rem; font-weight: 700; margin-bottom: 0.35rem; position: relative; z-index: 2; }
    .hero-subtitle { font-size: 0.9rem; opacity: 0.75; position: relative; z-index: 2; max-width: 520px; }
    .hero-stats { display: flex; gap: 2rem; margin-top: 1.5rem; position: relative; z-index: 2; flex-wrap: wrap; }
    .hero-stat-value { font-family: 'Outfit', sans-serif; font-size: 1.65rem; font-weight: 800; color: #fda4af; line-height: 1; }
    .hero-stat-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.5px; opacity: 0.6; margin-top: 4px; }
    .hero-ghost { position: absolute; right: -30px; bottom: -40px; font-size: 14rem; color: rgba(255,255,255,0.03); transform: rotate(-12deg); z-index: 1; pointer-events: none; }

    /* KPI Cards */
    .kpi-card {
        background: white; border: 1px solid var(--border); border-radius: var(--radius);
        padding: 1.5rem; box-shadow: var(--shadow-sm); display: flex; align-items: center; gap: 1.25rem;
    }
    .kpi-icon { width: 52px; height: 52px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.35rem; flex-shrink: 0; }
    .kpi-value { font-family: 'Outfit', sans-serif; font-size: 2rem; font-weight: 800; color: var(--navy); line-height: 1; }
    .kpi-label { font-size: 0.8rem; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.4px; margin-top: 3px; }

    /* Section label */
    .section-label { font-size: 0.68rem; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); margin-bottom: 0.85rem; }

    /* Premium card */
    .card-premium { background: white; border-radius: var(--radius); border: 1px solid var(--border); box-shadow: var(--shadow-sm); overflow: hidden; margin-bottom: 1.5rem; }
    .card-header-premium {
        padding: 1.1rem 1.75rem; background: white; border-bottom: 1px solid var(--border);
        display: flex; justify-content: space-between; align-items: center;
    }
    .card-title-premium { font-family: 'Outfit', sans-serif; font-weight: 700; font-size: 1.05rem; color: var(--navy); margin: 0; }

    /* Table */
    .table-premium { width: 100%; margin-bottom: 0; }
    .table-premium th { font-weight: 700; color: var(--navy); text-transform: uppercase; font-size: 0.72rem; letter-spacing: 0.05em; padding: 1rem 1.5rem; background: #f8fafc; border-bottom: 1.5px solid var(--border); }
    .table-premium td { padding: 1.1rem 1.5rem; border-bottom: 1px solid var(--border); font-size: 0.9rem; color: #334155; }
    .table-premium tr:last-child td { border-bottom: none; }

    /* Btn */
    .btn-prem { background: var(--rose); color: white; font-weight: 600; border: none; border-radius: 10px; padding: 0.5rem 1.1rem; font-size: 0.85rem; display: inline-flex; align-items: center; gap: 0.4rem; transition: all 0.2s; text-decoration: none; }
    .btn-prem:hover { background: #be123c; color: white; transform: translateY(-1px); box-shadow: 0 4px 10px rgba(225,29,72,0.2); }

    /* Badge estado */
    .badge-estado { padding: 0.28rem 0.65rem; border-radius: 9999px; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; }
    .badge-programado { background: #dbeafe; color: #1e40af; }
    .badge-triaje    { background: #fef3c7; color: #92400e; }
    .badge-listo     { background: var(--teal-light); color: var(--teal); }
    .badge-aviso     { background: var(--rose-light); color: var(--rose); }

    /* Empty state */
    .empty-state { text-align: center; padding: 2.5rem 1rem; color: var(--text-muted); }
    .empty-state i { font-size: 2.5rem; margin-bottom: 0.75rem; opacity: 0.3; display: block; }

    /* Search Card style */
    .search-card { background: white; border-radius: var(--radius); border: 1px solid var(--border); box-shadow: var(--shadow-sm); padding: 1.5rem 2rem; margin-bottom: 2rem; }
    .input-search-dni { border-radius: 12px; border: 1.5px solid var(--border); padding: 0.6rem 1rem; font-weight: 500; color: var(--navy); transition: all 0.2s; }
    .input-search-dni:focus { border-color: var(--rose); box-shadow: 0 0 0 3px rgba(225,29,72,0.1); outline: none; }

    /* Tabs Style */
    .nav-tabs .nav-link { transition: all 0.2s; border-bottom: 3px solid transparent !important; color: var(--text-muted); }
    .nav-tabs .nav-link.active { color: var(--rose) !important; border-bottom: 3px solid var(--rose) !important; font-weight: 700; }
    .nav-tabs .nav-link:hover { color: var(--rose) !important; }

    /* Kanban Board Layout */
    .kanban-board {
        display: flex;
        gap: 1.25rem;
        margin-bottom: 2.5rem;
        overflow-x: auto;
        padding-bottom: 1.5rem;
    }
    .kanban-col {
        flex: 1;
        min-width: 290px;
        background: #f8fafc;
        border-radius: var(--radius);
        border: 1px solid var(--border);
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        box-shadow: var(--shadow-sm);
    }
    .kanban-col-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 2px solid var(--border);
        padding-bottom: 0.75rem;
        margin-bottom: 0.25rem;
    }
    .kanban-col-title {
        font-family: 'Outfit', sans-serif;
        font-weight: 700;
        font-size: 0.95rem;
        color: var(--navy);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .kanban-col-count {
        background: var(--navy);
        color: white;
        font-size: 0.75rem;
        font-weight: 700;
        padding: 0.15rem 0.5rem;
        border-radius: 999px;
    }
    .kanban-cards {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        min-height: 250px;
        overflow-y: auto;
        max-height: 600px;
    }
    .kanban-card {
        background: white;
        border-radius: 16px;
        border: 1.5px solid var(--border);
        padding: 1rem 1.1rem;
        box-shadow: 0 2px 4px rgba(29,45,80,0.01);
        transition: all 0.2s ease-in-out;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
    }
    .kanban-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
        border-color: rgba(225,29,72,0.15);
    }
    .kanban-card-title {
        font-weight: 700;
        color: var(--navy);
        font-size: 0.88rem;
        margin: 0;
    }
    .kanban-card-meta {
        font-size: 0.78rem;
        color: var(--text-muted);
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }
    .kanban-card-info {
        background: #f1f5f9;
        border-radius: 8px;
        padding: 0.4rem 0.6rem;
        font-size: 0.78rem;
        color: #475569;
    }
    .triaje-vital-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0.4rem;
        background: var(--teal-light);
        color: #0f766e;
        border-radius: 10px;
        padding: 0.5rem;
        font-size: 0.75rem;
    }

    @@media (max-width: 768px) {
        .enf-page { padding: 1.5rem 1.25rem; }
        .hero-banner { padding: 1.75rem 1.5rem; }
        .welcome-title { font-size: 1.75rem; }
    }
</style>

<div class="enf-page">

    <!-- HEADER -->
    <header class="enf-header">
        <div>
            <h1 class="welcome-title" id="enf-greeting">
                Hola, <span style="color:#e11d48; font-weight:700;">@nombre</span> 👋
            </h1>
            <p class="welcome-subtitle">Panel de Enfermería — Posta de Salud Los Licenciados</p>
        </div>
        <div class="status-badge">
            <span class="badge-dot"></span>
            <i class="fa-solid fa-heart-pulse" style="color:var(--rose);"></i>
            Turno Activo
        </div>
    </header>

    <!-- NOTIFICACIONES -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 rounded-4 shadow-sm mb-4" role="alert" style="background:#e8f7f3; color:#2AAE8A;">
            <i class="fa-solid fa-circle-check me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 rounded-4 shadow-sm mb-4" role="alert" style="background:#fff1f2; color:#e11d48;">
            <i class="fa-solid fa-circle-xmark me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- BUSCADOR DNI (CU12) -->
    <div class="search-card">
        <h5 class="fw-bold mb-3" style="color: var(--navy);">
            <i class="fa-solid fa-magnifying-glass me-2" style="color: var(--rose);"></i>
            Iniciar Triaje por DNI
        </h5>
        <form asp-controller="Triaje" asp-action="BuscarCitaPorDni" method="get" class="row g-3 align-items-center">
            <div class="col-md-8">
                <input name="dni" type="text" pattern="\d{8}" maxlength="8" class="form-control input-search-dni" placeholder="Ingrese DNI del paciente (8 dígitos)..." required />
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn-prem w-100 py-3 d-flex justify-content-center align-items-center">
                    <i class="fa-solid fa-clipboard-pulse"></i> Buscar y Registrar
                </button>
            </div>
        </form>
    </div>

    <!-- HERO -->
    <div class="hero-banner mb-4">
        <div class="hero-logo"><i class="fa-solid fa-stethoscope text-white"></i></div>
        <h2 class="hero-title">Módulo de Triaje y Enfermería</h2>
        <p class="hero-subtitle">Registra los signos vitales de los pacientes en espera y gestiona los avisos de atención inmediata del día.</p>
        <div class="hero-stats">
            <div>
                <div class="hero-stat-value">@Model.CitasEnEspera.Count(c => c.EstadoCita == PostaCitasWeb.Entities.EstadoCita.Pendiente || c.EstadoCita == PostaCitasWeb.Entities.EstadoCita.EnTriaje)</div>
                <div class="hero-stat-label">En espera hoy</div>
            </div>
            <div>
                <div class="hero-stat-value">@totalAvisos</div>
                <div class="hero-stat-label">Avisos pendientes</div>
            </div>
        </div>
        <i class="fa-solid fa-notes-medical hero-ghost"></i>
    </div>

    <!-- KPIs -->
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="kpi-card">
                <div class="kpi-icon" style="background:var(--rose-light);">
                    <i class="fa-solid fa-user-clock" style="color:var(--rose);"></i>
                </div>
                <div>
                    <div class="kpi-value">@Model.CitasEnEspera.Count(c => c.EstadoCita == PostaCitasWeb.Entities.EstadoCita.Pendiente || c.EstadoCita == PostaCitasWeb.Entities.EstadoCita.EnTriaje)</div>
                    <div class="kpi-label">Pacientes en espera / triaje</div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="kpi-card">
                <div class="kpi-icon" style="background:var(--amber-light);">
                    <i class="fa-solid fa-triangle-exclamation" style="color:var(--amber);"></i>
                </div>
                <div>
                    <div class="kpi-value">@totalAvisos</div>
                    <div class="kpi-label">Avisos de atención inmediata</div>
                </div>
            </div>
        </div>
    </div>

    <!-- TABLERO KANBAN -->
    <div class="section-label">Tablero Kanban de Pacientes — Hoy</div>
    <div class="kanban-board">
        <!-- 1. Falta Triaje (Pendientes) -->
        @{
            var colPendientes = Model.CitasEnEspera.Where(c => c.EstadoCita == PostaCitasWeb.Entities.EstadoCita.Pendiente).ToList();
        }
        <div class="kanban-col" style="border-top: 4px solid var(--amber);">
            <div class="kanban-col-header">
                <h6 class="kanban-col-title">
                    <i class="fa-solid fa-clock-rotate-left" style="color:var(--amber);"></i>
                    Falta Triaje
                </h6>
                <span class="kanban-col-count" style="background:var(--amber);">@colPendientes.Count</span>
            </div>
            <div class="kanban-cards">
                @if (!colPendientes.Any())
                {
                    <div class="empty-state py-4 text-center">
                        <i class="fa-regular fa-face-smile" style="font-size: 1.5rem; opacity: 0.4;"></i>
                        <p class="mb-0 small mt-1">Sin pacientes en espera</p>
                    </div>
                }
                else
                {
                    @foreach (var cita in colPendientes)
                    {
                        var pacNombre = cita.Paciente != null ? $"{cita.Paciente.Nombres} {cita.Paciente.ApellidoPaterno}" : $"Cita #{cita.CitaId}";
                        var slotTime = cita.Slot != null ? $"{cita.Slot.HoraInicio.ToString(@"hh\:mm")} - {cita.Slot.HoraFin.ToString(@"hh\:mm")}" : "Horario N/A";
                        var medicoNombre = (cita.Slot?.Programacion?.Medico != null) ? $"{cita.Slot.Programacion.Medico.Nombres} {cita.Slot.Programacion.Medico.ApellidoPaterno}" : "Médico N/A";
                        
                        <div class="kanban-card">
                            <div class="d-flex justify-content-between align-items-start">
                                <span class="badge-estado badge-programado" style="font-size:0.6rem;">C-@cita.CitaId.ToString("D4")</span>
                                <small class="fw-bold" style="color:var(--rose); font-size:0.75rem;"><i class="fa-regular fa-clock"></i> @slotTime</small>
                            </div>
                            <h6 class="kanban-card-title">@pacNombre</h6>
                            <div class="kanban-card-meta">
                                <i class="fa-solid fa-user-doctor"></i> @medicoNombre
                            </div>
                            @if (cita.Paciente != null)
                            {
                                <div class="kanban-card-meta">
                                    <i class="fa-solid fa-id-card"></i> DNI: @cita.Paciente.DNI
                                </div>
                            }
                            <div class="mt-2">
                                <a asp-controller="Triaje" asp-action="Create" asp-route-id="@cita.CitaId" class="btn-prem w-100 py-2 justify-content-center" style="font-size: 0.78rem;">
                                    <i class="fa-solid fa-clipboard-pulse"></i> Registrar Triaje
                                </a>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- 2. En Triaje -->
        @{
            var colEnTriaje = Model.CitasEnEspera.Where(c => c.EstadoCita == PostaCitasWeb.Entities.EstadoCita.EnTriaje).ToList();
        }
        <div class="kanban-col" style="border-top: 4px solid var(--rose);">
            <div class="kanban-col-header">
                <h6 class="kanban-col-title">
                    <i class="fa-solid fa-heart-pulse" style="color:var(--rose);"></i>
                    En Triaje
                </h6>
                <span class="kanban-col-count" style="background:var(--rose);">@colEnTriaje.Count</span>
            </div>
            <div class="kanban-cards">
                @if (!colEnTriaje.Any())
                {
                    <div class="empty-state py-4 text-center">
                        <i class="fa-solid fa-stethoscope" style="font-size: 1.5rem; opacity: 0.4;"></i>
                        <p class="mb-0 small mt-1">Sin pacientes activos</p>
                    </div>
                }
                else
                {
                    @foreach (var cita in colEnTriaje)
                    {
                        var pacNombre = cita.Paciente != null ? $"{cita.Paciente.Nombres} {cita.Paciente.ApellidoPaterno}" : $"Cita #{cita.CitaId}";
                        var slotTime = cita.Slot != null ? $"{cita.Slot.HoraInicio.ToString(@"hh\:mm")} - {cita.Slot.HoraFin.ToString(@"hh\:mm")}" : "Horario N/A";
                        var medicoNombre = (cita.Slot?.Programacion?.Medico != null) ? $"{cita.Slot.Programacion.Medico.Nombres} {cita.Slot.Programacion.Medico.ApellidoPaterno}" : "Médico N/A";

                        <div class="kanban-card">
                            <div class="d-flex justify-content-between align-items-start">
                                <span class="badge-estado badge-triaje" style="font-size:0.6rem;">C-@cita.CitaId.ToString("D4")</span>
                                <small class="fw-bold text-danger" style="font-size:0.75rem;"><i class="fa-regular fa-clock"></i> @slotTime</small>
                            </div>
                            <h6 class="kanban-card-title">@pacNombre</h6>
                            <div class="kanban-card-meta">
                                <i class="fa-solid fa-user-doctor"></i> @medicoNombre
                            </div>
                            @if (cita.Paciente != null)
                            {
                                <div class="kanban-card-meta">
                                    <i class="fa-solid fa-id-card"></i> DNI: @cita.Paciente.DNI
                                </div>
                            }
                            <div class="d-flex flex-column gap-2 mt-2">
                                <form asp-controller="Enfermeria" asp-action="CambiarEstadoCita" method="post" class="w-100">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="citaId" value="@cita.CitaId" />
                                    <input type="hidden" name="estado" value="@PostaCitasWeb.Entities.EstadoCita.ListoAtencion" />
                                    <button type="submit" class="btn-prem border-0 w-100 py-2 justify-content-center" style="background:var(--teal); font-size: 0.78rem;">
                                        <i class="fa-solid fa-circle-check"></i> Listo Atención
                                    </button>
                                </form>
                                <form asp-controller="Enfermeria" asp-action="CambiarEstadoCita" method="post" class="w-100">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="citaId" value="@cita.CitaId" />
                                    <input type="hidden" name="estado" value="@PostaCitasWeb.Entities.EstadoCita.NoAsistio" />
                                    <button type="submit" class="btn-prem border-0 w-100 py-2 justify-content-center" style="background:var(--text-muted); font-size: 0.78rem;">
                                        <i class="fa-solid fa-user-slash"></i> No Asistió
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- 3. Listo Atención (Pasó Triaje) -->
        @{
            var colListoAtencion = Model.CitasEnEspera.Where(c => c.EstadoCita == PostaCitasWeb.Entities.EstadoCita.ListoAtencion).ToList();
        }
        <div class="kanban-col" style="border-top: 4px solid var(--teal);">
            <div class="kanban-col-header">
                <h6 class="kanban-col-title">
                    <i class="fa-solid fa-circle-check" style="color:var(--teal);"></i>
                    Listo Atención
                </h6>
                <span class="kanban-col-count" style="background:var(--teal);">@colListoAtencion.Count</span>
            </div>
            <div class="kanban-cards">
                @if (!colListoAtencion.Any())
                {
                    <div class="empty-state py-4 text-center">
                        <i class="fa-regular fa-circle-check" style="font-size: 1.5rem; opacity: 0.4;"></i>
                        <p class="mb-0 small mt-1">Sin pacientes triados</p>
                    </div>
                }
                else
                {
                    @foreach (var cita in colListoAtencion)
                    {
                        var pacNombre = cita.Paciente != null ? $"{cita.Paciente.Nombres} {cita.Paciente.ApellidoPaterno}" : $"Cita #{cita.CitaId}";
                        var slotTime = cita.Slot != null ? $"{cita.Slot.HoraInicio.ToString(@"hh\:mm")} - {cita.Slot.HoraFin.ToString(@"hh\:mm")}" : "Horario N/A";
                        var medicoNombre = (cita.Slot?.Programacion?.Medico != null) ? $"{cita.Slot.Programacion.Medico.Nombres} {cita.Slot.Programacion.Medico.ApellidoPaterno}" : "Médico N/A";

                        <div class="kanban-card">
                            <div class="d-flex justify-content-between align-items-start">
                                <span class="badge-estado badge-listo" style="font-size:0.6rem;">C-@cita.CitaId.ToString("D4")</span>
                                <small class="fw-bold" style="color:var(--teal); font-size:0.75rem;"><i class="fa-regular fa-clock"></i> @slotTime</small>
                            </div>
                            <h6 class="kanban-card-title">@pacNombre</h6>
                            <div class="kanban-card-meta">
                                <i class="fa-solid fa-user-doctor"></i> @medicoNombre
                            </div>
                            
                            <!-- Triaje Summary Signos Vitales -->
                            @if (cita.Triaje != null)
                            {
                                <div class="triaje-vital-grid mt-2">
                                    <div><i class="fa-solid fa-weight-scale me-1"></i> @cita.Triaje.Peso kg</div>
                                    <div><i class="fa-solid fa-ruler-vertical me-1"></i> @cita.Triaje.Talla cm</div>
                                    <div><i class="fa-solid fa-temperature-three-quarters me-1"></i> @cita.Triaje.Temperatura °C</div>
                                    <div><i class="fa-solid fa-gauge me-1"></i> @cita.Triaje.PresionSistolica/@cita.Triaje.PresionDiastolica mmHg</div>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(cita.Triaje.Observacion))
                                {
                                    <div class="kanban-card-info mt-1">
                                        <i class="fa-regular fa-comment-dots"></i> @cita.Triaje.Observacion
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-danger small mt-1"><i class="fa-solid fa-circle-exclamation"></i> Sin triaje registrado</div>
                            }
                        </div>
                    }
                }
            </div>
        </div>

        <!-- 4. Finalizados (No asistió / Cancelada) -->
        @{
            var colFinalizados = Model.CitasEnEspera.Where(c => c.EstadoCita == PostaCitasWeb.Entities.EstadoCita.NoAsistio || c.EstadoCita == PostaCitasWeb.Entities.EstadoCita.Cancelada).ToList();
        }
        <div class="kanban-col" style="border-top: 4px solid var(--text-muted);">
            <div class="kanban-col-header">
                <h6 class="kanban-col-title">
                    <i class="fa-solid fa-rectangle-list" style="color:var(--text-muted);"></i>
                    Finalizados
                </h6>
                <span class="kanban-col-count" style="background:var(--text-muted);">@colFinalizados.Count</span>
            </div>
            <div class="kanban-cards">
                @if (!colFinalizados.Any())
                {
                    <div class="empty-state py-4 text-center">
                        <i class="fa-solid fa-check-double" style="font-size: 1.5rem; opacity: 0.4;"></i>
                        <p class="mb-0 small mt-1">Sin citas finalizadas</p>
                    </div>
                }
                else
                {
                    @foreach (var cita in colFinalizados)
                    {
                        var pacNombre = cita.Paciente != null ? $"{cita.Paciente.Nombres} {cita.Paciente.ApellidoPaterno}" : $"Cita #{cita.CitaId}";
                        var slotTime = cita.Slot != null ? $"{cita.Slot.HoraInicio.ToString(@"hh\:mm")} - {cita.Slot.HoraFin.ToString(@"hh\:mm")}" : "Horario N/A";
                        var badgText = cita.EstadoCita == PostaCitasWeb.Entities.EstadoCita.NoAsistio ? "No asistió" : "Cancelada";
                        var badgClass = cita.EstadoCita == PostaCitasWeb.Entities.EstadoCita.NoAsistio ? "badge-estado badge-aviso" : "badge-estado badge-programado";

                        <div class="kanban-card" style="opacity: 0.75;">
                            <div class="d-flex justify-content-between align-items-start">
                                <span class="@badgClass" style="font-size:0.6rem;">@badgText</span>
                                <small class="text-muted" style="font-size:0.75rem;"><i class="fa-regular fa-clock"></i> @slotTime</small>
                            </div>
                            <h6 class="kanban-card-title text-muted">@pacNombre</h6>
                            @if (cita.Paciente != null)
                            {
                                <small class="text-muted"><i class="fa-solid fa-id-card"></i> DNI: @cita.Paciente.DNI</small>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <!-- TABLA AVISOS (CU17 / RF21) -->
    <div class="section-label">Avisos de atención inmediata</div>
    <div class="card-premium">
        <div class="card-header-premium border-0 pb-0">
            <span class="card-title-premium mb-3">
                <i class="fa-solid fa-triangle-exclamation me-2" style="color:var(--amber);"></i>
                Seguimiento de Avisos Inmediatos
            </span>
        </div>
        
        <!-- Pestañas de Estados -->
        <ul class="nav nav-tabs border-0 mb-3 px-4" id="avisoTabs" role="tablist" style="background:#f8fafc;">
            <li class="nav-item" role="presentation">
                <button class="nav-link active fw-bold text-uppercase border-0 position-relative pb-2" id="pendientes-tab" data-bs-toggle="tab" data-bs-target="#pendientes" type="button" role="tab" aria-controls="pendientes" aria-selected="true" style="background:transparent; font-size:0.75rem; letter-spacing:0.5px;">
                    Pendientes (@Model.AvisosPendientes.Count())
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold text-uppercase border-0 position-relative pb-2 ms-3" id="visualizados-tab" data-bs-toggle="tab" data-bs-target="#visualizados" type="button" role="tab" aria-controls="visualizados" aria-selected="false" style="background:transparent; font-size:0.75rem; letter-spacing:0.5px;">
                    Visualizados (@Model.AvisosVisualizados.Count())
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold text-uppercase border-0 position-relative pb-2 ms-3" id="cerrados-tab" data-bs-toggle="tab" data-bs-target="#cerrados" type="button" role="tab" aria-controls="cerrados" aria-selected="false" style="background:transparent; font-size:0.75rem; letter-spacing:0.5px;">
                    Cerrados (@Model.AvisosCerrados.Count())
                </button>
            </li>
        </ul>

        <div class="tab-content" id="avisoTabsContent">
            <!-- PESTAÑA PENDIENTES -->
            <div class="tab-pane fade show active" id="pendientes" role="tabpanel" aria-labelledby="pendientes-tab">
                @if (!Model.AvisosPendientes.Any())
                {
                    <div class="empty-state">
                        <i class="fa-regular fa-bell-slash"></i>
                        <p class="mb-0 fw-semibold">Sin avisos pendientes.</p>
                    </div>
                }
                else
                {
                    <table class="table-premium">
                        <thead>
                            <tr>
                                <th>Paciente</th>
                                <th>Hora de Envío</th>
                                <th>Motivo</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var aviso in Model.AvisosPendientes)
                            {
                                var pNombre = aviso.Paciente != null 
                                    ? $"{aviso.Paciente.Nombres} {aviso.Paciente.ApellidoPaterno} {aviso.Paciente.ApellidoMaterno}" 
                                    : $"Paciente #{aviso.PacienteId}";
                                <tr>
                                    <td style="font-weight:600; color:var(--navy);">@pNombre</td>
                                    <td>@aviso.FechaEnvio.ToLocalTime().ToString("g")</td>
                                    <td>@aviso.Motivo</td>
                                    <td>
                                        <div class="d-flex gap-2">
                                            <form asp-controller="Enfermeria" asp-action="CambiarEstadoAviso" method="post" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="avisoId" value="@aviso.AvisoId" />
                                                <input type="hidden" name="estado" value="@PostaCitasWeb.Entities.EstadoAviso.Visualizado" />
                                                <button type="submit" class="btn-prem border-0" style="background:var(--teal);">
                                                    <i class="fa-solid fa-eye"></i> Leer
                                                </button>
                                            </form>
                                            <form asp-controller="Enfermeria" asp-action="CambiarEstadoAviso" method="post" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="avisoId" value="@aviso.AvisoId" />
                                                <input type="hidden" name="estado" value="@PostaCitasWeb.Entities.EstadoAviso.Cerrado" />
                                                <button type="submit" class="btn-prem border-0" style="background:var(--text-muted);">
                                                    <i class="fa-solid fa-box-archive"></i> Cerrar
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>

            <!-- PESTAÑA VISUALIZADOS -->
            <div class="tab-pane fade" id="visualizados" role="tabpanel" aria-labelledby="visualizados-tab">
                @if (!Model.AvisosVisualizados.Any())
                {
                    <div class="empty-state">
                        <i class="fa-regular fa-eye-slash"></i>
                        <p class="mb-0 fw-semibold">No hay avisos visualizados recientemente.</p>
                    </div>
                }
                else
                {
                    <table class="table-premium">
                        <thead>
                            <tr>
                                <th>Paciente</th>
                                <th>Hora de Envío</th>
                                <th>Motivo</th>
                                <th>Acción</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var aviso in Model.AvisosVisualizados)
                            {
                                var pNombre = aviso.Paciente != null 
                                    ? $"{aviso.Paciente.Nombres} {aviso.Paciente.ApellidoPaterno} {aviso.Paciente.ApellidoMaterno}" 
                                    : $"Paciente #{aviso.PacienteId}";
                                <tr>
                                    <td style="font-weight:600; color:var(--navy);">@pNombre</td>
                                    <td>@aviso.FechaEnvio.ToLocalTime().ToString("g")</td>
                                    <td>@aviso.Motivo</td>
                                    <td>
                                        <form asp-controller="Enfermeria" asp-action="CambiarEstadoAviso" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="avisoId" value="@aviso.AvisoId" />
                                            <input type="hidden" name="estado" value="@PostaCitasWeb.Entities.EstadoAviso.Cerrado" />
                                            <button type="submit" class="btn-prem border-0" style="background:var(--text-muted);">
                                                <i class="fa-solid fa-box-archive"></i> Cerrar
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>

            <!-- PESTAÑA CERRADOS -->
            <div class="tab-pane fade" id="cerrados" role="tabpanel" aria-labelledby="cerrados-tab">
                @if (!Model.AvisosCerrados.Any())
                {
                    <div class="empty-state">
                        <i class="fa-solid fa-box-open"></i>
                        <p class="mb-0 fw-semibold">No hay avisos en el histórico de archivados/cerrados.</p>
                    </div>
                }
                else
                {
                    <table class="table-premium">
                        <thead>
                            <tr>
                                <th>Paciente</th>
                                <th>Hora de Envío</th>
                                <th>Motivo</th>
                                <th>Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var aviso in Model.AvisosCerrados)
                            {
                                var pNombre = aviso.Paciente != null 
                                    ? $"{aviso.Paciente.Nombres} {aviso.Paciente.ApellidoPaterno} {aviso.Paciente.ApellidoMaterno}" 
                                    : $"Paciente #{aviso.PacienteId}";
                                <tr>
                                    <td style="font-weight:600; color:var(--navy);">@pNombre</td>
                                    <td>@aviso.FechaEnvio.ToLocalTime().ToString("g")</td>
                                    <td>@aviso.Motivo</td>
                                    <td><span class="badge-estado badge-programado">Archivado / Cerrado</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    <!-- FOOTER -->
    <div class="text-center mt-5 pt-4" style="border-top:1px solid var(--border); font-size:0.72rem; color:var(--text-muted);">
        <strong>PostaCitasWeb v1.0</strong> — Solo personal con rol <strong>Enfermería</strong> tiene acceso a este panel.
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const h = new Date().getHours();
            const n = "@nombre";
            const w = h < 12 ? "Buenos días" : h < 19 ? "Buenas tardes" : "Buenas noches";
            document.getElementById('enf-greeting').innerHTML =
                `${w}, <span style="color:#e11d48;font-weight:700;">${n}</span> 👋`;
        })();
    </script>
}

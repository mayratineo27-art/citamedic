@model PostaCitasWeb.Models.ViewModels.TriajeCreateViewModel
@{
    ViewData["Title"] = "Registrar Triaje";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold" style="color: #008B8B;">Registrar Triaje</h2>
            <p class="text-muted mb-0">Evaluación inicial de signos vitales para el paciente</p>
        </div>
        <a asp-controller="Enfermeria" asp-action="Index" class="btn btn-outline-secondary">← Volver al Panel</a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="modern-card p-4">
                <form asp-action="Create" method="post" class="needs-validation">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="CitaId" />

                    <h5 class="mb-4 border-bottom pb-2" style="color: #008B8B;">Información de la Cita</h5>
                    <div class="row mb-4 bg-light p-3 rounded">
                        <div class="col-md-6 mb-2 mb-md-0">
                            <span class="text-muted d-block small">Paciente</span>
                            <strong class="text-dark">@Model.PacienteNombre</strong>
                        </div>
                        <div class="col-md-6">
                            <span class="text-muted d-block small">Especialidad</span>
                            <strong class="text-dark">@Model.EspecialidadNombre</strong>
                        </div>
                    </div>

                    <h5 class="mb-4 border-bottom pb-2" style="color: #008B8B;">Signos Vitales</h5>
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Peso" class="form-label fw-bold">Peso (kg)</label>
                            <input asp-for="Peso" type="number" step="0.1" class="form-control" placeholder="Ej: 70.5" required />
                            <span asp-validation-for="Peso" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Talla" class="form-label fw-bold">Talla (cm)</label>
                            <input asp-for="Talla" type="number" step="0.1" class="form-control" placeholder="Ej: 172" required />
                            <span asp-validation-for="Talla" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="Temperatura" class="form-label fw-bold">Temperatura (°C)</label>
                            <input asp-for="Temperatura" type="number" step="0.1" class="form-control" placeholder="Ej: 36.5" required />
                            <span asp-validation-for="Temperatura" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="PresionSistolica" class="form-label fw-bold">Presión Sistólica (mmHg)</label>
                            <input asp-for="PresionSistolica" type="number" class="form-control" placeholder="Ej: 120" required />
                            <span asp-validation-for="PresionSistolica" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="PresionDiastolica" class="form-label fw-bold">Presión Diastólica (mmHg)</label>
                            <input asp-for="PresionDiastolica" type="number" class="form-control" placeholder="Ej: 80" required />
                            <span asp-validation-for="PresionDiastolica" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Observacion" class="form-label fw-bold">Observación (Opcional)</label>
                        <textarea asp-for="Observacion" class="form-control" rows="3" placeholder="Comentarios o notas de triaje..."></textarea>
                        <span asp-validation-for="Observacion" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4 border-top pt-3">
                        <a asp-controller="Enfermeria" asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                        <button type="submit" class="btn btn-teal">💾 Guardar Triaje</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
